# Prod Env

# Backend
BACKEND_VERSION=1.0.0   # Версия backend приложения
GO_VERSION=1.26         # Версия go

# Frontend
FRONTEND_VERSION=1.0.0  # Версия frontend приложения
NODE_VERSION=26         # Версия node

# Usage
TZ=Europe/Moscow # Укажите ваш часовой пояс для корректного отображения времени в логах и приложении
NGINX_PORT=80 # Внешний порт для доступа к приложению
DOCKER_USER=your_dockerhub_username # Имя пользователя на Docker Hub
